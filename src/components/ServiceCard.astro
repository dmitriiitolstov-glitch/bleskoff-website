---
interface Props {
	index: string;
	title: string;
	slug: string;
	lead: string;
	description: string;
	image: string;
	priceFrom?: string;
}

const { index, title, slug, lead, description, image, priceFrom } = Astro.props;
---

<article class="service-card reveal">
	<div class="service-media">
		<img src={image} alt={title} width="1024" height="768" loading="lazy" />
		<span>{index}</span>
	</div>
	<div class="service-copy">
		<h3>{title}</h3>
		<p><strong>{lead}</strong> {description}</p>
		{priceFrom && <small class="service-price">Стоимость {priceFrom}</small>}
		<a href={`/services/${slug}/`}>Подробнее об услуге <span aria-hidden="true">↗</span></a>
	</div>
</article>
