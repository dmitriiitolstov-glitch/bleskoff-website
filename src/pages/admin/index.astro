---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { isCmsConfigured } from "../../lib/cms";
---

<BaseLayout title="Админка BleskOFF" description="Управление содержимым сайта BleskOFF" noindex={true}>
	<main class="admin-shell">
		<section class="admin-card">
			<a class="admin-brand" href="/">BLESK<span>OFF</span></a>
			<p class="admin-kicker">Управление сайтом</p>
			{isCmsConfigured ? (
				<>
					<h1>Админка готова к работе</h1>
					<p>Откройте редактор, войдите в аккаунт Sanity и выберите нужный раздел. После публикации изменения появятся на сайте при следующей сборке.</p>
					<a class="admin-button" href="/studio/">Открыть редактор <span>→</span></a>
				</>
			) : (
				<>
					<h1>Админка подготовлена</h1>
					<p>Код редактора уже установлен. Чтобы включить вход для клиента, нужно один раз создать бесплатный проект Sanity и добавить его идентификатор в настройки публикации.</p>
					<div class="admin-status"><span></span> Ожидает подключения Sanity</div>
					<a class="admin-button admin-button--secondary" href="/">Вернуться на сайт <span>→</span></a>
				</>
			)}
			<div class="admin-features">
				<div><b>01</b><strong>Контент</strong><span>Акции, услуги, программы и FAQ</span></div>
				<div><b>02</b><strong>SEO</strong><span>Заголовок, описание и картинка сайта</span></div>
				<div><b>03</b><strong>Доступ</strong><span>Отдельная учётная запись клиента</span></div>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.admin-shell { min-height: 100svh; display: grid; place-items: center; padding: 24px; background: #111; color: #f4f1eb; }
	.admin-card { width: min(960px, 100%); padding: clamp(32px, 7vw, 88px); border: 1px solid #393939; background: #181818; }
	.admin-brand { display: inline-block; margin-bottom: 72px; color: inherit; font: 800 22px/1 sans-serif; letter-spacing: .06em; text-decoration: none; }
	.admin-brand span { color: #ed1c24; }
	.admin-kicker { margin: 0 0 18px; color: #ed1c24; font: 700 12px/1.2 sans-serif; letter-spacing: .16em; text-transform: uppercase; }
	h1 { max-width: 720px; margin: 0 0 22px; font: 500 clamp(40px, 7vw, 76px)/.98 sans-serif; letter-spacing: -.055em; }
	.admin-card > p:not(.admin-kicker) { max-width: 680px; margin: 0; color: #aaa; font: 400 18px/1.55 sans-serif; }
	.admin-button { display: flex; justify-content: space-between; align-items: center; width: min(360px, 100%); margin-top: 38px; padding: 20px 22px; background: #ed1c24; color: #fff; font: 700 15px/1 sans-serif; text-decoration: none; transition: background .2s ease; }
	.admin-button:hover { background: #cf121a; }
	.admin-button--secondary { background: #2b2b2b; }
	.admin-button--secondary:hover { background: #363636; }
	.admin-status { display: flex; align-items: center; gap: 10px; margin-top: 28px; color: #ddd; font: 600 14px/1.4 sans-serif; }
	.admin-status span { width: 9px; height: 9px; border-radius: 50%; background: #e5a734; box-shadow: 0 0 0 5px rgb(229 167 52 / 12%); }
	.admin-features { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; margin-top: 72px; background: #363636; border: 1px solid #363636; }
	.admin-features div { display: grid; gap: 10px; padding: 22px; background: #181818; }
	.admin-features b { color: #ed1c24; font: 600 11px/1 sans-serif; }
	.admin-features strong { font: 650 16px/1.2 sans-serif; }
	.admin-features span { color: #858585; font: 400 13px/1.45 sans-serif; }
	@media (max-width: 700px) { .admin-brand { margin-bottom: 48px; } .admin-features { grid-template-columns: 1fr; margin-top: 48px; } }
</style>
